<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Card body -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#EEF2F7" />
        </shape>
    </item>
    <!-- Top accent bar -->
    <item android:top="0dp" android:bottom="-14dp" android:left="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <size android:height="3dp" />
            <solid android:color="#344EAD" />
            <corners android:topLeftRadius="14dp" android:topRightRadius="14dp"
                android:bottomLeftRadius="0dp" android:bottomRightRadius="0dp" />
        </shape>
    </item>
</layer-list>
