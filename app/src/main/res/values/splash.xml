<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Background of the splash screen -->
        <item name="windowSplashScreenBackground">#111827</item> <!-- Rich Dark Gray -->
        
        <!-- Icon to be displayed in the center -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        
        <!-- Duration the splash screen is displayed -->
        <item name="windowSplashScreenAnimationDuration">800</item>
        
        <!-- Theme to switch to after the splash screen is done -->
        <item name="postSplashScreenTheme">@style/Theme.BlueprintProApps</item>
    </style>
</resources>
