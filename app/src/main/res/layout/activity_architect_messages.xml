<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".network.ArchitectMessagesActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textColor="#0F172A"
                android:textSize="28sp"
                android:fontFamily="@font/raleway_bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect and collaborate with your clients"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:fontFamily="@font/raleway_regular"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Matched Clients Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Matched Clients"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="@font/raleway_bold"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="16dp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/architectRecyclerChatHeads"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingHorizontal="24dp"
                    android:overScrollMode="never" />
            </LinearLayout>

            <!-- Conversations Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="100dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Chats"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="@font/raleway_bold"
                    android:paddingHorizontal="24dp"
                    android:layout_marginBottom="16dp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/architectRecyclerMessages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/architectBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        style="@style/Widget.BlueprintPro.BottomNavigation"
        app:menu="@menu/bottom_nav_menu_architect" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
