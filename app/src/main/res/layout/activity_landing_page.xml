<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/bg_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bldg_bg"
        android:scaleType="centerCrop"
        android:scaleX="1.1"
        android:scaleY="1.1" />

    <!-- Overlay for dark effect -->
    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_auth_overlay" />

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/hero_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="28dp"
            android:paddingTop="80dp"
            android:paddingBottom="32dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/logo"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/bpp_logo_updated"
                android:contentDescription="BlueprintPro Logo"
                android:layout_marginBottom="24dp" />

            <!-- Brand Title -->
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BlueprintPro"
                android:textSize="32sp"
                android:letterSpacing="0.04"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/raleway_bold" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/tagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connect. Share. Build."
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:alpha="0.8"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/raleway_regular" />

            <!-- Description -->
            <TextView
                android:id="@+id/description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Connecting people, designs, and progress—architecture made simple."
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:alpha="0.7"
                android:gravity="center"
                android:layout_marginBottom="32dp"
                android:paddingHorizontal="16dp"
                android:fontFamily="@font/raleway_regular" />

            <!-- Get Started Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGetStarted"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Get Started"
                android:textSize="16sp"
                android:letterSpacing="0.02"
                app:cornerRadius="14dp"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/raleway_bold" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
