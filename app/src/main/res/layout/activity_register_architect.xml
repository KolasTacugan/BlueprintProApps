<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register_main_architect"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".network.RegisterArchitectActivity">

    <!-- Immersive Background -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bldg_bg"
        android:scaleType="centerCrop"
        android:scaleX="1.1"
        android:scaleY="1.1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_auth_overlay" />

    <ScrollView
        android:id="@+id/register_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="28dp"
            android:paddingTop="80dp"
            android:paddingBottom="32dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/bpp_logo_updated" />

            <!-- Architect Header Section -->
            <TextView
                android:id="@+id/tvRegisterTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Architect Registration"
                android:textColor="@android:color/white"
                android:textSize="24sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.7"
                android:fontFamily="@font/raleway_regular"
                android:text="Join the elite network of developers"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- Stepper Progress Indicator -->
            <TextView
                android:id="@+id/tvStepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Step 1 of 3: Profile Details"
                android:textColor="#82B1FF"
                android:textSize="13sp"
                android:letterSpacing="0.05" />

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/stepProgress"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:indicatorColor="#82B1FF"
                app:trackColor="#33FFFFFF"
                app:trackCornerRadius="4dp"
                android:max="3"
                android:progress="1" />

            <!-- Step 1 Container -->
            <LinearLayout
                android:id="@+id/step1Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Section: Personal Details -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/firstNameLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:hint="First Name"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                android:textColorHint="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/firstNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="textPersonName"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/lastNameLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Last Name"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                android:textColorHint="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/lastNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="textPersonName"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/phoneNumberLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Phone Number"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                android:textColorHint="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/phoneNumberInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="phone"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Email Address"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                android:textColorHint="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="textEmailAddress"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Step 2 Container -->
            <LinearLayout
                android:id="@+id/step2Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passwordLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Password"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconMode="password_toggle"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="textPassword"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>



            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/confirmPasswordLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Confirm Password"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconMode="password_toggle"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/confirmPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="textPassword"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Step 3 Container -->
            <LinearLayout
                android:id="@+id/step3Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

            <!-- Section: Professional Credentials -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Professional Credentials"
                android:textColor="@android:color/white"
                android:textSize="15sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/licenseNoLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="License Number"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:hintTextColor="@android:color/white"
                app:startIconTint="#82B1FF"
                app:endIconTint="#82B1FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/licenseNoInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:inputType="text"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Professional Dropdowns -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/styleLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Architectural Style"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:endIconTint="@android:color/white"
                app:hintTextColor="@android:color/white">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/raleway_regular"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/budgetLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Project Budget Range"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:endIconTint="@android:color/white"
                app:hintTextColor="@android:color/white">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoBudget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/raleway_regular"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/locationLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Service Location"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:endIconTint="@android:color/white"
                app:hintTextColor="@android:color/white">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/raleway_regular"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/specializationLayout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Professional Specialization"
                android:textColorHint="@android:color/white"
                app:boxBackgroundColor="#4DFFFFFF"
                app:boxCornerRadiusBottomEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusTopStart="14dp"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeColor="@android:color/white"
                app:endIconTint="@android:color/white"
                app:hintTextColor="@android:color/white">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/autoSpecialization"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@android:color/white"
                    android:fontFamily="@font/raleway_regular"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Complete Registration Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackArchitect"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/raleway_bold"
                    android:letterSpacing="0.02"
                    android:text="Back"
                    android:textColor="@android:color/white"
                    android:visibility="gone" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/registerButtonArchitect"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:fontFamily="@font/raleway_bold"
                        android:letterSpacing="0.02"
                        android:text="Next Step"
                        android:textSize="16sp"
                        app:cornerRadius="14dp" />

                    <LinearLayout
                        android:id="@+id/registerProgressLayoutArchitect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:indeterminate="true"
                            app:indicatorColor="@android:color/white"
                            app:indicatorSize="20dp"
                            app:trackThickness="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:fontFamily="@font/raleway_bold"
                            android:text="REGISTERING..."
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Login Link Container -->
            <LinearLayout
                android:id="@+id/loginLinkContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_regular"
                    android:text="Already have an account? "
                    android:textColor="@android:color/white"
                    android:alpha="0.7"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_bold"
                    android:text="Login"
                    android:textColor="@android:color/white"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
