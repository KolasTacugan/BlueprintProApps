<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    style="?attr/materialCardViewElevatedStyle">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Blueprint Image with Price Badge -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp">

            <ImageView
                android:id="@+id/blueprintImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="Blueprint Image" />

            <!-- Price Badge Overlay -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                style="?attr/materialCardViewFilledStyle"
                app:cardBackgroundColor="?attr/colorPrimary">
                
                <TextView
                    android:id="@+id/blueprintPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0"
                    android:textColor="?attr/colorOnPrimary"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp" />
            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- Content Section -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Blueprint Name -->
            <TextView
                android:id="@+id/blueprintName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modern Villa"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Blueprint Description -->
            <TextView
                android:id="@+id/blueprintDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Luxurious 4-bedroom villa"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Add to Cart Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/addToCartBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add to Cart"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
