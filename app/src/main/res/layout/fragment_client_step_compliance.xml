<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp"
        android:clipChildren="false">

        <!-- Stage Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/stepTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compliance &amp; Permits"
                    android:textColor="#0F172A"
                    android:textSize="22sp"
                    android:fontFamily="@font/raleway_bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Review zoning permits and regulatory compliance files."
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:fontFamily="@font/raleway_regular"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Document Sections -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZONING DOCUMENTS"
            android:textColor="#475569"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/zoningFilesContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTHER COMPLIANCE"
            android:textColor="#475569"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/otherFilesContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
