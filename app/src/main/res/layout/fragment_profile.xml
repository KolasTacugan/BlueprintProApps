<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/web_bg"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="132dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/raleway_bold"
                    android:letterSpacing="-0.01"
                    android:text="Profile"
                    android:textColor="@color/web_text_heading"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Manage account details, plan, and role-specific resources."
                    android:textColor="@color/web_text_subtitle"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/slate_200" />

            <TextView
                android:id="@+id/tvProfileState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Loading profile..."
                android:textColor="@color/web_text_body"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetryProfile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="Try Again"
                android:textAllCaps="false"
                android:visibility="gone"
                app:backgroundTint="@color/web_blue"
                app:cornerRadius="14dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileHeaderCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/slate_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <FrameLayout
                        android:layout_width="82dp"
                        android:layout_height="82dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgProfile"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#F1F5F9"
                            android:scaleType="centerCrop"
                            android:src="@drawable/sample_profile"
                            app:shapeAppearanceOverlay="@style/CircleImage" />

                        <TextView
                            android:id="@+id/tvProBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|end"
                            android:background="@drawable/bg_pro_badge"
                            android:fontFamily="@font/raleway_bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:text="PRO"
                            android:textColor="@android:color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="@font/raleway_bold"
                            android:maxLines="1"
                            android:text="User"
                            android:textColor="@color/web_text_heading"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvRoleBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_status_chip_outline"
                            android:fontFamily="@font/raleway_bold"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="5dp"
                            android:text="ROLE"
                            android:textColor="@color/web_blue"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="email@example.com"
                            android:textColor="@color/web_text_body"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="N/A"
                            android:textColor="@color/web_text_body"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_button"
                        android:padding="12dp"
                        android:scaleType="centerInside"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/web_text_heading" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutArchitectCredentials"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_section_icon_badge">

                        <ImageView
                            android:id="@+id/icArchitectDetails"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            app:tint="@color/web_blue" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/raleway_bold"
                        android:text="Architect Details"
                        android:textColor="@color/web_text_heading"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/slate_200"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/tvArchitectStyle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Style: N/A"
                            android:textColor="@color/web_text_heading"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvArchitectSpecialization"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Specialization: N/A"
                            android:textColor="@color/web_text_body"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvArchitectLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Location: N/A"
                            android:textColor="@color/web_text_body"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvArchitectBudget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Labor cost: N/A"
                            android:textColor="@color/web_text_body"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPortfolioText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:ellipsize="end"
                            android:maxLines="4"
                            android:text="Portfolio summary unavailable."
                            android:textColor="@color/web_text_body"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvCredentialsFile"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/bg_status_chip_outline"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="@font/raleway_bold"
                            android:padding="12dp"
                            android:text="Credentials: N/A"
                            android:textColor="@color/web_blue"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnManagePlan"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="14dp"
                            android:text="Manage Plan"
                            android:textAllCaps="false"
                            app:backgroundTint="@color/web_blue"
                            app:cornerRadius="14dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutPurchasedBlueprints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_section_icon_badge">

                        <ImageView
                            android:id="@+id/icPurchasedBlueprints"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            app:tint="@color/web_blue" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/raleway_bold"
                        android:text="Purchased Blueprints"
                        android:textColor="@color/web_text_heading"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPurchasedEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Loading purchases..."
                    android:textColor="@color/web_text_body"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPurchasedBlueprints"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_purchased_blueprint" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/raleway_bold"
                android:text="Log Out"
                android:textAllCaps="false"
                android:textColor="#EF4444"
                android:textSize="16sp"
                app:backgroundTint="#FEE2E2"
                app:cornerRadius="16dp"
                app:elevation="0dp"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconTint="#EF4444" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
