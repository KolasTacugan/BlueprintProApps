<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp"
        android:clipChildren="false">

        <!-- Stage Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/stepTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compliance &amp; Permits"
                    android:textColor="#0F172A"
                    android:textSize="22sp"
                    android:fontFamily="@font/raleway_bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage zoning permits and regulatory compliance documents."
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:fontFamily="@font/raleway_regular"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- File Upload Center -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Document"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:fontFamily="@font/raleway_bold"
                    android:layout_marginBottom="18dp" />

                <RadioGroup
                    android:id="@+id/fileTypeGroup"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <RadioButton
                        android:id="@+id/zoningRadio"
                        android:text="Zoning"
                        android:checked="true"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:fontFamily="@font/raleway_regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="#2563EB" />

                    <RadioButton
                        android:id="@+id/otherRadio"
                        android:text="Others"
                        android:textColor="#334155"
                        android:textSize="14sp"
                        android:fontFamily="@font/raleway_regular"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="#2563EB" />
                </RadioGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/uploadComplianceBtn"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Select &amp; Upload"
                    android:textAllCaps="false"
                    android:fontFamily="@font/raleway_bold"
                    android:textColor="#FFFFFF"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#2563EB"
                    app:icon="@drawable/ic_work"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Document Sections -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZONING DOCUMENTS"
            android:textColor="#475569"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/zoningFilesContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OTHER COMPLIANCE"
            android:textColor="#475569"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:id="@+id/otherFilesContainer"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp" />

        <!-- Next Action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextBtn"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Advance to Finalization"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="@font/raleway_bold"
            android:textColor="#FFFFFF"
            app:cornerRadius="18dp"
            app:backgroundTint="#0F172A"
            app:elevation="4dp"
            app:icon="@drawable/ic_match"
            app:iconGravity="textEnd"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>
</ScrollView>
