<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusableInTouchMode="true"
    android:focusable="true"
    android:background="@color/light_gray">

    <!-- ═══ TOP BAR ═══ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/appLogo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/bpp_logo"
            app:tint="@color/primary"
            android:contentDescription="Logo"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Architect Match"
                android:textSize="18sp"
                android:textColor="@color/on_surface"
                android:fontFamily="@font/raleway_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI-powered assistant"
                android:textSize="12sp"
                android:textColor="@color/slate_500"
                android:fontFamily="@font/raleway_regular"/>
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/slate_500"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ═══ CHAT SCROLL AREA ═══ -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/chatScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:background="@color/slate_50"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inputBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Welcome Bubble -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="start"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="280dp"
                    android:text="Hi! Tell me about your project — the style, scale, and budget — and I'll match you with the best architects."
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="@font/raleway_regular"
                    android:padding="16dp"
                    android:background="@drawable/bg_ai_bubble"/>
            </LinearLayout>

            <!-- Chat History -->
            <LinearLayout
                android:id="@+id/chatHistoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Clarification Questions -->
            <LinearLayout
                android:id="@+id/clarificationScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/clarificationInner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- AI Feedback -->
            <LinearLayout
                android:id="@+id/aiFeedbackContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/aiFeedbackText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="280dp"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="@font/raleway_regular"
                    android:padding="16dp"
                    android:background="@drawable/bg_ai_bubble"/>
            </LinearLayout>

            <!-- Results -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/matchRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══ INPUT BAR ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="16dp"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@color/white">

            <EditText
                android:id="@+id/clientPrompt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="48dp"
                android:hint="Type your project description..."
                android:background="@drawable/slate_100_rounded"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:textSize="15sp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/slate_500"
                android:fontFamily="@font/raleway_regular"
                android:imeOptions="actionSend"
                android:inputType="textMultiLine"
                android:maxLines="4"/>

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_circle_primary"
                android:src="@android:drawable/ic_menu_send"
                app:tint="@color/white"
                android:scaleType="centerInside"
                android:elevation="4dp"
                android:contentDescription="Send"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ═══ LOADING OVERLAY ═══ -->
    <LinearLayout
        android:id="@+id/loadingSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_glass_card"
        android:padding="32dp"
        android:elevation="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Finding the perfect match..."
            android:textColor="@color/slate_700"
            android:fontFamily="@font/raleway_bold"
            android:textSize="14sp"
            android:layout_marginTop="16dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
