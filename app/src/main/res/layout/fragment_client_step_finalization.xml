<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:clipChildren="false">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp"
        android:clipChildren="false">

        <!-- Stage Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E2E8F0">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/stepTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Finalization"
                    android:textColor="#0F172A"
                    android:textSize="22sp"
                    android:fontFamily="@font/raleway_bold"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Review your final blueprints and finalize project handover."
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:fontFamily="@font/raleway_regular"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Final Blueprint Section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Final Blueprint"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:fontFamily="@font/raleway_bold"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/finalFileNameText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Waiting for final handover..."
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:fontFamily="@font/raleway_regular"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Handover Notes -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HANDOVER NOTES"
            android:textColor="#475569"
            android:textSize="11sp"
            android:fontFamily="@font/raleway_bold"
            android:textAllCaps="true"
            android:letterSpacing="0.12"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/finalizationNotesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No handover notes provided."
                    android:textColor="#334155"
                    android:textSize="15sp"
                    android:fontFamily="@font/raleway_regular"
                    android:minHeight="120dp"
                    android:gravity="top|start"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Feedback Center -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/ratingCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#0F172A"
            app:strokeWidth="0dp">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate Your Experience"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="@font/raleway_bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How was your collaboration with the architect?"
                    android:textColor="#94A3B8"
                    android:textSize="13sp"
                    android:fontFamily="@font/raleway_regular"
                    android:layout_marginBottom="24dp" />

                <RatingBar
                    android:id="@+id/ratingBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:stepSize="1"
                    android:layout_gravity="center_horizontal"
                    android:progressTint="#FBBF24"
                    android:progressBackgroundTint="#334155"
                    android:secondaryProgressTint="#FBBF24" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/submitRatingBtn"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Submit Review"
                    android:textAllCaps="false"
                    android:fontFamily="@font/raleway_bold"
                    android:textColor="#0F172A"
                    app:cornerRadius="16dp"
                    app:backgroundTint="#FFFFFF"
                    android:layout_marginTop="28dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
