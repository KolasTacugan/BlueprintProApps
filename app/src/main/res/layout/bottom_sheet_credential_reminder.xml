<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="28dp"
    android:background="@color/white">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:layout_marginBottom="20dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="Portfolio icon" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Your Architect Portfolio"
        android:textSize="20sp"
        android:fontFamily="@font/raleway_bold"
        android:textColor="@color/primary"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload your credential file in your Profile to appear in the AI-powered architect matching and get discovered by clients."
        android:textSize="14sp"
        android:fontFamily="@font/raleway_regular"
        android:textColor="@color/dark_gray"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="28dp" />

    <Button
        android:id="@+id/btnGoToProfile"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Go to Profile"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:fontFamily="@font/raleway_bold"
        android:background="@drawable/bg_primary_button"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnMaybeLater"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Maybe Later"
        android:textColor="@color/primary"
        android:textSize="15sp"
        android:fontFamily="@font/raleway_regular"
        android:background="@android:color/transparent"
        android:layout_marginBottom="4dp" />

</LinearLayout>
