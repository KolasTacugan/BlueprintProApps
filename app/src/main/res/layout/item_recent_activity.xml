<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEF2F7"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp"
        android:background="?attr/selectableItemBackground">

        <ImageView
            android:id="@+id/ivActivityIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_section_icon_badge"
            android:padding="8dp"
            android:scaleType="centerInside" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvActivityTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/web_text_heading"
                android:textSize="14sp"
                android:fontFamily="@font/raleway_bold"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvActivitySubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/web_text_body"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/web_text_subtitle" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>