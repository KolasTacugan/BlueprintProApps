<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:orientation="horizontal"
        android:weightSum="3">

        <View
            android:id="@+id/strengthBar1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@color/slate_200"
            android:backgroundTint="@color/slate_200" />

        <View
            android:id="@+id/strengthBar2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@color/slate_200"
            android:backgroundTint="@color/slate_200" />

        <View
            android:id="@+id/strengthBar3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@color/slate_200"
            android:backgroundTint="@color/slate_200" />
    </LinearLayout>

    <TextView
        android:id="@+id/strengthText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/raleway_bold"
        android:text="Too weak"
        android:textAllCaps="true"
        android:textColor="@color/slate_500"
        android:textSize="10sp"
        android:visibility="gone" />

</LinearLayout>
