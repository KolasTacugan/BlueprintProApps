<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F7F9"
    android:clipToPadding="false"
    android:clipChildren="false">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Project Tracker"
                    android:textColor="#0F172A"
                    android:textSize="26sp"
                    android:fontFamily="@font/raleway_bold"
                    android:letterSpacing="-0.01" />

                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Real-time progress tracking"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:fontFamily="@font/raleway_regular"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_button"
                android:src="@drawable/ic_arrow_back"
                android:padding="10dp"
                android:scaleType="centerInside"
                app:tint="#0F172A" />
        </LinearLayout>

        <!-- Project Info Strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:paddingBottom="20dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/architectNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_chip_outline"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Architect: Loading..."
                android:textColor="#475569"
                android:textSize="11sp"
                android:fontFamily="@font/raleway_bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="12dp"
                android:background="#E2E8F0" />

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONGOING"
                android:textColor="#3B82F6"
                android:textSize="11sp"
                android:fontFamily="@font/raleway_bold"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9" />
    </LinearLayout>

    <!-- Premium Stepper Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/stepperCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#EEF2F7"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Connecting Lines -->
            <View
                android:id="@+id/line1"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#E2E8F0"
                app:layout_constraintTop_toTopOf="@id/step1Circle"
                app:layout_constraintBottom_toBottomOf="@id/step1Circle"
                app:layout_constraintStart_toEndOf="@id/step1Circle"
                app:layout_constraintEnd_toStartOf="@id/step2Circle" />

            <View
                android:id="@+id/line2"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="#E2E8F0"
                app:layout_constraintTop_toTopOf="@id/step2Circle"
                app:layout_constraintBottom_toBottomOf="@id/step2Circle"
                app:layout_constraintStart_toEndOf="@id/step2Circle"
                app:layout_constraintEnd_toStartOf="@id/step3Circle" />

            <!-- Step 1 Circle -->
            <FrameLayout
                android:id="@+id/step1Circle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_stepper_circle"
                android:backgroundTint="#344EAD"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/ic1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_review"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <TextView
                android:id="@+id/label1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Review"
                android:textSize="11sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="#344EAD"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/step1Circle"
                app:layout_constraintStart_toStartOf="@id/step1Circle"
                app:layout_constraintEnd_toEndOf="@id/step1Circle" />

            <!-- Step 2 Circle -->
            <FrameLayout
                android:id="@+id/step2Circle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_stepper_circle"
                android:backgroundTint="#E2E8F0"
                app:layout_constraintStart_toEndOf="@id/line1"
                app:layout_constraintEnd_toStartOf="@id/line2"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/ic2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_compliance"
                    app:tint="#64748B" />
            </FrameLayout>

            <TextView
                android:id="@+id/label2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Compliance"
                android:textSize="11sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="#64748B"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/step2Circle"
                app:layout_constraintStart_toStartOf="@id/step2Circle"
                app:layout_constraintEnd_toEndOf="@id/step2Circle" />

            <!-- Step 3 Circle -->
            <FrameLayout
                android:id="@+id/step3Circle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_stepper_circle"
                android:backgroundTint="#E2E8F0"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView
                    android:id="@+id/ic3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_finalization"
                    app:tint="#64748B" />
            </FrameLayout>

            <TextView
                android:id="@+id/label3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Finalization"
                android:textSize="11sp"
                android:fontFamily="@font/raleway_bold"
                android:textColor="#64748B"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/step3Circle"
                app:layout_constraintStart_toStartOf="@id/step3Circle"
                app:layout_constraintEnd_toEndOf="@id/step3Circle" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ViewPager Content -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/stepViewPager"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/stepperCard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
